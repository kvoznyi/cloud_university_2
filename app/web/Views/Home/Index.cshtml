@model WorkoutPlanner.Models.WorkoutRequest
@{
    ViewData["Title"] = "Dashboard";
}

<section class="hero">
    <h1>🏋️ Workout Planner</h1>
    <p class="hero-subtitle">AI-powered personalized workout recommendations</p>
</section>

<section class="form-section">
    <h2>Tell us about yourself</h2>
    <form asp-controller="Home" asp-action="Result" method="post" class="workout-form">

        <div class="form-group">
            <label asp-for="Age">Age</label>
            <input asp-for="Age" type="number" min="10" max="100" class="form-control" />
        </div>

        <div class="form-group">
            <label asp-for="Weight">Weight (kg)</label>
            <input asp-for="Weight" type="number" step="0.1" min="30" max="300" class="form-control" />
        </div>

        <div class="form-group">
            <label asp-for="Height">Height (cm)</label>
            <input asp-for="Height" type="number" step="0.1" min="100" max="250" class="form-control" />
        </div>

        <div class="form-group">
            <label asp-for="Goal">Fitness Goal</label>
            <select asp-for="Goal" class="form-control">
                <option value="general_fitness">General Fitness</option>
                <option value="weight_loss">Weight Loss</option>
                <option value="muscle_gain">Muscle Gain</option>
                <option value="flexibility">Flexibility</option>
                <option value="endurance">Endurance</option>
            </select>
        </div>

        <div class="form-group">
            <label asp-for="FitnessLevel">Current Fitness Level</label>
            <select asp-for="FitnessLevel" class="form-control">
                <option value="beginner">Beginner</option>
                <option value="intermediate">Intermediate</option>
                <option value="advanced">Advanced</option>
            </select>
        </div>

        <button type="submit" class="btn btn-primary">Get Recommendation</button>
    </form>
</section>

<section class="features">
    <h2>How it works</h2>
    <div class="feature-grid">
        <div class="feature-card">
            <div class="feature-icon">📊</div>
            <h3>Activity Recognition</h3>
            <p>ML model trained on 19 sport activities using accelerometer, gyroscope, and magnetometer data.</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon">🤖</div>
            <h3>Smart Recommendations</h3>
            <p>Personalized workout plans based on your fitness level, goals, and recognized activity patterns.</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon">☁️</div>
            <h3>Cloud-Powered</h3>
            <p>Deployed on Azure with auto-scaling, monitoring, and high availability.</p>
        </div>
    </div>
</section>
